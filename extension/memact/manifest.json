{
  "manifest_version": 3,
  "name": "Memact",
  "version": "0.7.0",
  "description": "Capture browser tab context for Memact.",
  "icons": {
    "16": "icons/memact_16.png",
    "32": "icons/memact_32.png",
    "48": "icons/memact_48.png",
    "128": "icons/memact_128.png"
  },
  "permissions": ["tabs", "windows", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:38453/*",
    "http://localhost:38453/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Memact",
    "default_icon": {
      "16": "icons/memact_16.png",
      "32": "icons/memact_32.png",
      "48": "icons/memact_48.png",
      "128": "icons/memact_128.png"
    }
  }
}
