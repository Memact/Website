VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
# Optional override for non-standard deploy domains. Defaults to the current origin.
# VITE_AUTH_REDIRECT_URL=http://localhost:3000/Access
# Optional Supabase Edge Function used by the Account tab invite button.
# VITE_SUPABASE_INVITE_FUNCTION=invite-user
# Optional Supabase Edge Function used by the Account tab delete-account button.
# Requires a server-side function with service-role permissions. Never delete Auth users from browser code.
# VITE_SUPABASE_DELETE_ACCOUNT_FUNCTION=delete-account
# Optional Supabase Edge Function that returns requires_verification=true when a password sign-in needs an email code, for example after an IP change.
# VITE_SUPABASE_SIGNIN_RISK_FUNCTION=signin-risk-check

# Optional local fallback only:
# VITE_MEMACT_ACCESS_URL=http://127.0.0.1:8787
