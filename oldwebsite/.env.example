GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=180
GEMINI_TEMPERATURE=0.1
VITE_MEMACT_AI_MODE=fallback
MEMACT_ALLOWED_ORIGINS=http://localhost:5173,https://memact.com,https://www.memact.com
MEMACT_API_PORT=8787
MEMACT_RATE_LIMIT_WINDOW_MS=60000
MEMACT_RATE_LIMIT_MAX_REQUESTS=30
MEMACT_MAX_QUERY_LENGTH=240
VITE_MEMACT_GEMINI_ENDPOINT=/api/gemini-answer
# Optional. If omitted, Memact derives this from VITE_MEMACT_GEMINI_ENDPOINT.
VITE_MEMACT_GEMINI_FOLLOWUP_ENDPOINT=/api/gemini-followups
# Optional. If omitted, Memact derives this from VITE_MEMACT_GEMINI_ENDPOINT.
VITE_MEMACT_GEMINI_HISTORY_TITLE_ENDPOINT=/api/gemini-history-title
